    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
        <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
        <material name="MatPlane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
        <material name="rubber" rgba="0.4 0.4 0.4 1" shininess="0.5" reflectance="0.2"/>

        <mesh name="base_link"           file="../mesh_v3_2/base_link_modified.STL" />
        <mesh name="left_hip_link"       file="../mesh_v3_2/left_hip_link.STL" />
        <mesh name="left_shoulder_link"  file="../mesh_v3_2/left_shoulder_link.STL" />
        <mesh name="left_leg_link"       file="../mesh_v3_2/left_leg_link.STL" />
        <mesh name="left_wheel_link"     file="../mesh_v3_2/left_wheel_link.STL" />
        <mesh name="right_hip_link"      file="../mesh_v3_2/right_hip_link.STL" />
        <mesh name="right_shoulder_link" file="../mesh_v3_2/right_shoulder_link.STL" />
